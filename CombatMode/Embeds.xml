<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">
    <!-- LIBS -->
    <Script file="Libs\LibStub\LibStub.lua"/>
    <Include file="Libs\LibEditMode\embed.xml"/>
    <Include file="Libs\CallbackHandler-1.0\CallbackHandler-1.0.xml"/>
    <Include file="Libs\AceAddon-3.0\AceAddon-3.0.xml"/>
    <Include file="Libs\AceEvent-3.0\AceEvent-3.0.xml"/>
    <Include file="Libs\AceDB-3.0\AceDB-3.0.xml"/>
    <Include file="Libs\AceConsole-3.0\AceConsole-3.0.xml"/>
    <Include file="Libs\AceGUI-3.0\AceGUI-3.0.xml"/>
    <Include file="Libs\AceConfig-3.0\AceConfig-3.0.xml"/>
    <!-- FEATURES (Core must load before Constants.lua — Constants uses GetAddon("CombatMode").) -->
    <Script file="Features\Core.lua"/>
    <Script file="Features\Constants.lua"/>
    <Script file="Features\ClickCasting.lua"/>
    <Script file="Features\Pulse.lua"/>
    <Script file="Features\Reticle.lua"/>
    <Script file="UI\CrosshairEditMode.lua"/>
    <Script file="Features\CursorUnlock.lua"/>
    <Script file="Features\HealingRadial.lua"/>
    <!-- CONFIG: AceConfig — OptionsShared first, Config.lua last -->
    <Script file="Config\OptionsShared.lua"/>
    <Script file="Config\AboutOptions.lua"/>
    <Script file="Config\MouseLookOptions.lua"/>
    <Script file="Config\ReticleTargetingOptions.lua"/>
    <Script file="Config\ClickCastingOptions.lua"/>
    <Script file="Config\HealingRadialOptions.lua"/>
    <Script file="Config\AdvancedOptions.lua"/>
    <Script file="Config\Config.lua"/>
    <!-- FRAME -->
    <Frame name="CombatModeFrame" hidden="false" parent="UIParent" inherits="SecureHandlerStateTemplate">
        <Scripts>
            <OnUpdate function="CombatMode_OnUpdate"/>
            <OnEvent function="CombatMode_OnEvent"/>
        </Scripts>
    </Frame>
</Ui>
